# ==============================================================================
# Environment Configuration Template for Dynamic MCP Skill Hub
# Copy this file to '.env' and fill in the values before running the application.
# ==============================================================================

# General Configuration
NODE_ENV=production
PORT=3030

# LLM Providers & API Keys
# At least one provider (Gemini, Groq, or NVIDIA) must be configured.
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro

# Search API Configuration
TAVILY_API_KEY=your_tavily_api_key_here

# LLM Control Parameters
MODEL_TIMEOUT_MS=60000
MODEL_MAX_RETRIES=2

# Workspace Directories (Paths relative to project root or absolute paths)
TOOL_WORKSPACE_DIR=workspace
TOOL_REGISTRY_DIR=workspace/tools
RUNTIME_DIR=workspace/runtime
LOG_DIR=workspace/logs

# Tool Behavior and Policy Configs
AUTO_PUBLISH_LOW_RISK=true
REQUIRE_APPROVAL_FOR_DESTRUCTIVE=true

# Execution Sandbox Configuration
# Modes: "local" (run directly on host) or "docker" (run inside runner container)
SANDBOX_MODE=docker
DOCKER_TOOL_IMAGE=dynamic-mcp-skill-runner:latest
